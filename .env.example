# KZO InspectPro — Variables d'environnement
# Copier ce fichier vers .env et remplir les valeurs
# ⚠️  Ne jamais committer .env dans git

# ─── Provider IA actif ───────────────────────────────────────────────
# Valeurs possibles : groq | gemini | openai | anthropic
KZO_PROVIDER=gemini

# ─── Clés API IA ─────────────────────────────────────────────────────
KZO_GROQ_API_KEY=
KZO_GEMINI_API_KEY=
KZO_OPENAI_API_KEY=
KZO_ANTHROPIC_API_KEY=

# ─── Google Sheets / Apps Script ─────────────────────────────────────
KZO_SHEETS_WEBHOOK_URL=

# ─── Google Drive OAuth ──────────────────────────────────────────────
KZO_GOOGLE_DRIVE_CLIENT_ID=

# ─── EmailJS ─────────────────────────────────────────────────────────
KZO_EMAILJS_SERVICE_ID=
KZO_EMAILJS_TEMPLATE_ID=
KZO_EMAILJS_RAPPORT_TEMPLATE_ID=
KZO_EMAILJS_PUBLIC_KEY=

# ─── Profil inspecteur ───────────────────────────────────────────────
KZO_INSPECTOR_NAME=
KZO_PHONE=
KZO_EMAIL=
KZO_ADDRESS=
KZO_TPS=
KZO_TVQ=
